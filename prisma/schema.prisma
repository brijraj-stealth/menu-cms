generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum Permission {
  VIEW
  ADD
  EDIT
  DELETE
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole @default(STAFF)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  propertyAccess UserPropertyAccess[]
  venueAccess    UserVenueAccess[]
  menuAccess     UserMenuAccess[]
  activityLogs   ActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Global Allergens ─────────────────────────────────────────────────────────

model Allergen {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  itemAllergens ItemAllergen[]
}

// ─── Hierarchy: Property → Venue → Menu → Category → SubCategory → Item ──────

model Property {
  id          String   @id @default(cuid())
  name        String
  description String?
  location    String?
  slug        String   @unique
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  venues     Venue[]
  userAccess UserPropertyAccess[]
}

model Venue {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  image       String?
  isActive    Boolean  @default(true)
  propertyId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  menus      Menu[]
  userAccess UserVenueAccess[]
}

model Menu {
  id                       String   @id @default(cuid())
  name                     String
  description              String?
  slug                     String?  @unique
  phoneNumber              String?
  phoneButtonText          String?
  videoSectionHeader       String?
  videoSectionSubheader    String?
  featuredSectionHeader    String?
  featuredSectionSubheader String?
  scheduleText             String?
  image                    String?
  currency                 String   @default("AED")
  allergenDescription      String?  @db.Text
  taxDescription           String?  @db.Text
  isActive                 Boolean  @default(true)
  venueId                  String
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  venue           Venue               @relation(fields: [venueId], references: [id], onDelete: Cascade)
  categories      Category[]
  superCategories SuperCategory[]
  textBlocks      TextBlock[]
  userAccess      UserMenuAccess[]
  videos          MenuVideo[]
  featuredImages  MenuFeaturedImage[]
}

model MenuVideo {
  id        String   @id @default(cuid())
  menuId    String
  url       String
  title     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model MenuFeaturedImage {
  id        String   @id @default(cuid())
  menuId    String
  url       String
  title     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model SuperCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  menuId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  categories Category[]
}

model TextBlock {
  id        String   @id @default(cuid())
  content   String   @db.Text
  sortOrder Int      @default(0)
  menuId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model Category {
  id                String   @id @default(cuid())
  name              String
  description       String?
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  showAddToCart     Boolean  @default(true)
  showAllergenInfo  Boolean  @default(false)
  showTaxInfo       Boolean  @default(false)
  menuId            String
  superCategoryId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  menu          Menu           @relation(fields: [menuId], references: [id], onDelete: Cascade)
  superCategory SuperCategory? @relation(fields: [superCategoryId], references: [id], onDelete: SetNull)
  subCategories SubCategory[]
}

model SubCategory {
  id            String   @id @default(cuid())
  name          String
  description   String?
  sortOrder     Int      @default(0)
  displayMode   String   @default("LIST")
  isActive      Boolean  @default(true)
  showAddToCart Boolean  @default(true)
  categoryId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    Item[]
}

model Item {
  id            String   @id @default(cuid())
  name          String
  description   String?  @db.Text
  basePrice     Decimal  @db.Decimal(10, 2)
  image         String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  showAddToCart Boolean  @default(true)
  subCategoryId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subCategory   SubCategory    @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  variants      ItemVariant[]
  itemAllergens ItemAllergen[]
}

model ItemVariant {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  itemId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ItemAllergen {
  itemId     String
  allergenId String

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  allergen Allergen @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([itemId, allergenId])
}

// ─── User Access Control ──────────────────────────────────────────────────────

model UserPropertyAccess {
  id          String       @id @default(cuid())
  userId      String
  propertyId  String
  permissions Permission[]
  createdAt   DateTime     @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
}

model UserVenueAccess {
  id          String       @id @default(cuid())
  userId      String
  venueId     String
  permissions Permission[]
  createdAt   DateTime     @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

model UserMenuAccess {
  id          String       @id @default(cuid())
  userId      String
  menuId      String
  permissions Permission[]
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@unique([userId, menuId])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
